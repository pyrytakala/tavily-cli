{
  "name": "tavily-cli",
  "version": "0.1.0",
  "description": "CLI for the Tavily AI search API - search, extract, crawl, and map the web",
  "type": "module",
  "bin": {
    "tavily-cli": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target bun",
    "dev": "bun run src/index.ts"
  },
