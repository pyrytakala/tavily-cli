    "type": "git",
    "url": "https://github.com/pyrytakala/tavily-cli.git"
  },
  "license": "MIT",
  "engines": {
    "bun": ">=1.0"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
